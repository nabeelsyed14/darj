{
  "name": "darj",
  "version": "0.1.0",
  "description": "School Database Management System for Indian government schools",
  "author": "Darj",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/postbuild.js",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "antd": "^5.23.1",
    "app-builder-bin": "^5.0.0-alpha.10",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.13",
    "exceljs": "^4.4.0",
    "i18next": "^24.2.1",
    "papaparse": "^5.5.1",
    "png-to-ico": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.1.3",
    "recharts": "^3.8.1",
    "sql.js": "^1.12.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.darj.app",
    "productName": "Darj",
    "icon": "assets/logo.ico",
    "directories": {
      "output": "releases",
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis",
      "icon": "logo.ico",
      "signAndEditExecutable": false
    },
    "linux": {
      "icon": "logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Darj",
      "installerIcon": "assets/logo.ico",
      "uninstallerIcon": "assets/logo.ico",
      "installerHeaderIcon": "assets/logo.ico"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ]
  }
}













































